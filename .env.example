# Responio — Environment Variables Template
# Copy to .env for local development:
#   cp .env.example .env
# NEVER commit .env to git.

# ── Database ──────────────────────────────────
POSTGRES_USER=responio
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=responio_development
DATABASE_URL=postgresql://responio:change_me_in_production@localhost:5432/responio_development

# ── Redis ─────────────────────────────────────
REDIS_PASSWORD=change_me_in_production
REDIS_URL=redis://:change_me_in_production@localhost:6379/0

# ── NATS ──────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Object Storage (MinIO / AWS S3) ───────────
MINIO_ROOT_USER=responio_admin
MINIO_ROOT_PASSWORD=change_me_in_production
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_MEDIA=responio-media
S3_BUCKET_DOCUMENTS=responio-documents
S3_ACCESS_KEY=responio_admin
S3_SECRET_KEY=change_me_in_production
S3_REGION=us-east-1

# ── Monitoring ────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_in_production

# ── ClickHouse (Analytics) ───────────────────
CLICKHOUSE_DB=responio_analytics
CLICKHOUSE_USER=responio
CLICKHOUSE_PASSWORD=change_me_in_production
CLICKHOUSE_URL=http://localhost:8123

# ── Stripe Billing ────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Plan Price IDs (from Stripe dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...
STRIPE_PRICE_ADVANCED_MONTHLY=price_...
STRIPE_PRICE_ADVANCED_ANNUAL=price_...
STRIPE_PRICE_SEAT_ADDON_STARTER=price_...
STRIPE_PRICE_SEAT_ADDON_GROWTH=price_...
STRIPE_PRICE_SEAT_ADDON_ADVANCED=price_...

# ── LLM / AI ──────────────────────────────────
LITELLM_MASTER_KEY=change_me_in_production
LITELLM_API_BASE=http://localhost:4000

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp BSP ──────────────────────────────
# 360dialog
DIALOG360_API_KEY=
DIALOG360_PARTNER_TOKEN=
# Twilio (fallback BSP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ── Auth (Authentik) ──────────────────────────
AUTHENTIK_URL=http://localhost:9000
AUTHENTIK_TOKEN=
JWT_SECRET=change_me_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# ── n8n (Workflow Engine — headless) ─────────
# ADR-001 DECIDED: n8n headless
N8N_API_KEY=dev_n8n_api_key_change_in_prod
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://n8n:5678
N8N_ENCRYPTION_KEY=dev_n8n_encryption_key_change_in_prod

# ── App Config ────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001

# ── ACME / TLS ────────────────────────────────
ACME_EMAIL=admin@responio.io

# ── Encryption ────────────────────────────────
ENCRYPTION_KEY=change_me_32_char_hex_string_here
